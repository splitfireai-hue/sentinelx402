# Database
# SQLite (local dev, zero setup):
DATABASE_URL=sqlite+aiosqlite:///./sentinelx402.db
# PostgreSQL (production):
# DATABASE_URL=postgresql+asyncpg://sentinel:sentinel@localhost:5432/sentinelx402

# Redis (optional — leave empty for in-memory cache)
REDIS_URL=
# REDIS_URL=redis://localhost:6379/0

# x402 Payment Configuration
WALLET_ADDRESS=0xYourWalletAddressHere
FACILITATOR_URL=https://x402.org/facilitator
NETWORK_ID=eip155:84532
X402_ENABLED=false

# NVD API (optional, increases rate limit from 5/30s to 50/30s)
NVD_API_KEY=

# App
ENVIRONMENT=development
LOG_LEVEL=INFO

# CORS (comma-separated origins, empty = allow all in dev)
ALLOWED_ORIGINS=

# Rate Limiting
THREAT_RATE_LIMIT=60/minute
CVE_RATE_LIMIT=30/minute

# Timeouts
NVD_TIMEOUT_SECONDS=15
